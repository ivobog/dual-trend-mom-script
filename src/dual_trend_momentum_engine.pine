export clampScore(float value) =>
    math.max(0.0, math.min(10.0, value))

export rocPct(series float source, int lookback) =>
    not na(source[lookback]) and source[lookback] != 0.0
         ? (source - source[lookback]) / source[lookback] * 100.0
         : 0.0

export slopePct(series float source, int lookback) =>
    not na(source[lookback]) and source[lookback] != 0.0
         ? (source - source[lookback]) / source[lookback] * 100.0
         : 0.0

export slopeAtr(series float source, int lookback, series float atrValue) =>
    not na(source[lookback]) and atrValue > 0.0
         ? (source - source[lookback]) / atrValue
         : 0.0

export pctDistance(float valueA, float valueB, float denominator, float fallback) =>
    denominator != 0.0 ? math.abs(valueA - valueB) / denominator * 100.0 : fallback

export rollingSum(series float source, int length) =>
    math.sum(source, length)

export distributionBar(float volumeMultiplier, int averageVolumeLength) =>
    distributionAvgVol = ta.sma(volume, averageVolumeLength)
    close < open and volume > distributionAvgVol * volumeMultiplier and close < close[1] ? 1.0 : 0.0
