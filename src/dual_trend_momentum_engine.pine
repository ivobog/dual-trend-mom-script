//@version=6
library("DualTrendMomentumEngine", overlay=false)

// ============================================================================
// Dual Trend + Momentum Engine
// Engine version: 3.2.0
//
// Future v3 import path after publishing:
// import ivobog/DualTrendMomentumEngine/3 as engine
//
// This version exports the larger pure score/classification modules while the
// caller keeps request.security data collection and chart/order rendering local.
// ============================================================================

export engineVersion() =>
    "3.2.0"

export classPrimePullback() =>
    "Prime clean pullback"

export classCleanPullback() =>
    "Clean bull pullback"

export classFreshBreakout() =>
    "Fresh breakout"

export classMomentumContinuation() =>
    "Momentum continuation"

export classExtendedMomentum() =>
    "Extended momentum"

export classOverheatedMomentum() =>
    "Overheated momentum"

export classFilteredPullback() =>
    "Filtered pullback"

export classFilteredMomentum() =>
    "Filtered momentum"

export classTrendRepair() =>
    "Trend repair"

export classDistributionRisk() =>
    "Distribution risk"

export classBlowoffTop() =>
    "Blowoff top"

export classFailedBreakout() =>
    "Failed breakout"

export classNoTrade() =>
    "No trade"

export pullbackHealthy() =>
    "Healthy"

export pullbackMixed() =>
    "Mixed"

export pullbackDangerous() =>
    "Dangerous"

export marketBullish() =>
    "Bullish"

export marketMixed() =>
    "Mixed"

export marketBearish() =>
    "Bearish"

export marketRiskOff() =>
    "Risk-off"

export rsStrong() =>
    "Strong"

export rsNeutral() =>
    "Neutral"

export rsWeak() =>
    "Weak"

export htfStrong() =>
    "Strong"

export htfNeutral() =>
    "Neutral"

export htfWeak() =>
    "Weak"

export clampScore(float value) =>
    math.max(0.0, math.min(10.0, value))

export rocPct(series float source, int lookback) =>
    not na(source[lookback]) and source[lookback] != 0.0
         ? (source - source[lookback]) / source[lookback] * 100.0
         : 0.0

export slopePct(series float source, int lookback) =>
    not na(source[lookback]) and source[lookback] != 0.0
         ? (source - source[lookback]) / source[lookback] * 100.0
         : 0.0

export slopeAtr(series float source, int lookback, series float atrValue) =>
    not na(source[lookback]) and atrValue > 0.0
         ? (source - source[lookback]) / atrValue
         : 0.0

export pctDistance(float valueA, float valueB, float denominator, float fallback) =>
    denominator != 0.0 ? math.abs(valueA - valueB) / denominator * 100.0 : fallback

export rollingSum(series float source, int length) =>
    math.sum(source, length)

export distributionBar(float volumeMultiplier, int averageVolumeLength) =>
    distributionAvgVol = ta.sma(volume, averageVolumeLength)
    close < open and volume > distributionAvgVol * volumeMultiplier and close < close[1] ? 1.0 : 0.0

export relativeStrengthScore(bool rsAboveSma, float rsRocShort, float rsRocMedium, float rsRocLong, bool beatsShort, bool beatsMedium, bool beatsLong, bool rsNewHighValue) =>
    score = 0.0
    score += rsAboveSma ? 2.0 : 0.0
    score += rsRocShort > 0.0 ? 1.5 : 0.0
    score += rsRocMedium > 0.0 ? 1.5 : 0.0
    score += rsRocLong > 0.0 ? 1.0 : 0.0
    score += beatsShort ? 1.5 : 0.0
    score += beatsMedium ? 1.5 : 0.0
    score += beatsLong ? 0.5 : 0.0
    score += rsNewHighValue ? 0.5 : 0.0
    clampScore(score)

export combinedRelativeStrengthScore(float benchmarkScore, float sectorScore, bool useSectorBenchmark) =>
    useSectorBenchmark ? clampScore(benchmarkScore * 0.70 + sectorScore * 0.30) : benchmarkScore

export relativeStrengthStatus(float score) =>
    score >= 7.0 ? rsStrong() : score >= 4.5 ? rsNeutral() : rsWeak()

export htfScore(bool dataReady, bool closeAboveSlow, bool closeAboveMid, bool fastAboveMid, bool midAboveSlow, float midSlopePct, float slowSlopePct, float htfRoc, bool stackStrong, bool stackBasic) =>
    score = 0.0
    score += dataReady and closeAboveSlow ? 2.00 : 0.0
    score += dataReady and closeAboveMid ? 1.50 : 0.0
    score += dataReady and fastAboveMid ? 1.25 : 0.0
    score += dataReady and midAboveSlow ? 1.50 : 0.0
    score += midSlopePct > 0.0 ? 1.25 : 0.0
    score += slowSlopePct > 0.0 ? 1.00 : 0.0
    score += htfRoc > 0.0 ? 1.00 : 0.0
    score += stackStrong ? 0.50 : stackBasic ? 0.25 : 0.0
    clampScore(score)

export htfStatus(float score) =>
    score >= 7.0 ? htfStrong() : score >= 4.5 ? htfNeutral() : htfWeak()

export localTrendScore(bool abovePullbackEma, bool pullbackAboveMid, bool midAboveTrend, bool trendAboveSlow, bool aboveSlow, bool maStackStrong, float midSlopePct, float slowSlopePct, float midSlopeAtr, float slowSlopeAtr, float adxValue, float minAdxTrend, bool plusDiAboveMinus, bool adxRising, bool plusDiRising, float position52, bool near52High, bool higherHigh, bool higherLow, bool aboveClose20High) =>
    score = 0.0
    score += abovePullbackEma ? 0.50 : 0.0
    score += pullbackAboveMid ? 0.50 : 0.0
    score += midAboveTrend ? 0.60 : 0.0
    score += trendAboveSlow ? 0.60 : 0.0
    score += aboveSlow ? 0.40 : 0.0
    score += maStackStrong ? 0.40 : 0.0
    score += midSlopePct > 0.0 ? 0.50 : 0.0
    score += slowSlopePct > 0.0 ? 0.40 : 0.0
    score += midSlopeAtr > 0.50 ? 0.50 : midSlopeAtr > 0.20 ? 0.30 : 0.0
    score += slowSlopeAtr > 0.25 ? 0.40 : slowSlopeAtr > 0.10 ? 0.20 : 0.0
    score += midSlopePct > slowSlopePct ? 0.20 : 0.0
    score += adxValue >= minAdxTrend ? 0.70 : adxValue >= 14.0 ? 0.35 : 0.0
    score += plusDiAboveMinus ? 0.70 : 0.0
    score += adxRising ? 0.30 : 0.0
    score += plusDiRising ? 0.30 : 0.0
    score += position52 >= 70.0 ? 0.80 : position52 >= 50.0 ? 0.40 : 0.0
    score += near52High ? 0.70 : 0.0
    score += higherHigh ? 0.50 : 0.0
    score += higherLow ? 0.50 : 0.0
    score += aboveClose20High ? 0.50 : 0.0
    clampScore(score)

export blendedTrendScore(float localScore, float htfScoreValue, bool blendHtfIntoTrendScore, bool htfDataReady) =>
    blendHtfIntoTrendScore and htfDataReady ? clampScore(localScore * 0.80 + htfScoreValue * 0.20) : localScore

export momentumScore(float combinedRsScore, float rsRocShort, float rsRocMedium, bool rsNewHighValue, float stockRocShort, float stockRocMedium, float stockRocLong, bool beatsBenchmarkShort, bool beatsBenchmarkMedium, float rsiValue, bool rsiRising, float rsiPullbackLow, bool greenBeatsRed, bool obvRising, bool bullishVolumeBar, bool breakoutVolumeConfirmed, bool volumeDryUp, float strongClose, bool priceRising, bool aboveFastEma) =>
    score = 0.0
    score += combinedRsScore >= 8.0 ? 1.40 : combinedRsScore >= 6.5 ? 1.00 : combinedRsScore >= 5.0 ? 0.50 : 0.0
    score += rsRocShort > 0.0 ? 0.50 : 0.0
    score += rsRocMedium > 0.0 ? 0.50 : 0.0
    score += rsNewHighValue ? 0.60 : 0.0
    score += stockRocShort > 3.0 ? 0.60 : stockRocShort > 0.0 ? 0.30 : 0.0
    score += stockRocMedium > 8.0 ? 0.70 : stockRocMedium > 0.0 ? 0.35 : 0.0
    score += stockRocLong > 15.0 ? 0.50 : stockRocLong > 0.0 ? 0.25 : 0.0
    score += beatsBenchmarkShort ? 0.35 : 0.0
    score += beatsBenchmarkMedium ? 0.35 : 0.0
    score += rsiValue >= 55.0 and rsiValue <= 70.0 ? 0.70 : rsiValue >= 50.0 and rsiValue <= 75.0 ? 0.40 : 0.0
    score += rsiRising ? 0.30 : 0.0
    score += rsiPullbackLow > 40.0 ? 0.30 : 0.0
    score += rsiPullbackLow < 50.0 and rsiValue > 55.0 ? 0.20 : 0.0
    score += greenBeatsRed ? 0.45 : 0.0
    score += obvRising ? 0.45 : 0.0
    score += bullishVolumeBar ? 0.40 : 0.0
    score += breakoutVolumeConfirmed ? 0.40 : 0.0
    score += volumeDryUp ? 0.30 : 0.0
    score += strongClose >= 0.70 ? 0.40 : strongClose >= 0.60 ? 0.20 : 0.0
    score += priceRising ? 0.30 : 0.0
    score += aboveFastEma ? 0.30 : 0.0
    clampScore(score)

export setupScore(bool hadPullback, bool notTooDeep, bool heldNearSupport, float pullbackDepthPct, float minPullbackPct, bool volumeDryUp, bool redVolDeclining, bool abovePullbackEma, bool aboveMidMa, bool priceRising, float strongClose, bool freshBreakout, bool aboveClose10High, bool bullishBreakoutVolume, bool aboveFastEma, float extensionMidPct, float extensionWarnPct, bool rewardRiskOk, float rsiValue, float atrPct, float atrWarnPct, bool heavyRedNow, float distributionCount, bool failedBreakout, bool gapExhaustion) =>
    score = 0.0
    score += hadPullback and notTooDeep ? 1.00 : 0.0
    score += heldNearSupport ? 0.80 : 0.0
    score += pullbackDepthPct >= minPullbackPct and pullbackDepthPct <= 10.0 ? 0.50 : 0.0
    score += volumeDryUp ? 0.40 : 0.0
    score += redVolDeclining ? 0.30 : 0.0
    score += abovePullbackEma ? 0.50 : 0.0
    score += aboveMidMa ? 0.60 : 0.0
    score += priceRising ? 0.40 : 0.0
    score += strongClose >= 0.65 ? 0.50 : 0.0
    score += freshBreakout ? 0.80 : 0.0
    score += aboveClose10High ? 0.40 : 0.0
    score += bullishBreakoutVolume ? 0.40 : 0.0
    score += aboveFastEma ? 0.40 : 0.0
    score += extensionMidPct <= extensionWarnPct ? 0.80 : 0.0
    score += rewardRiskOk ? 0.50 : 0.0
    score += rsiValue >= 50.0 and rsiValue <= 70.0 ? 0.50 : 0.0
    score += atrPct <= atrWarnPct ? 0.20 : 0.0
    score += not heavyRedNow ? 0.30 : 0.0
    score += distributionCount < 3.0 ? 0.30 : 0.0
    score += not failedBreakout and not gapExhaustion ? 0.40 : 0.0
    clampScore(score)

export riskScore(float extensionMidPct, float extensionWarnPct, float extensionDangerPct, float rsiValue, bool nearResistance, bool freshBreakout, bool heavyRedNow, float distributionCount, bool failedBreakout, bool gapExhaustion, bool liquidityWarning, float atrPct, float atrWarnPct, float atrDangerPct, bool marketRiskOffValue, string marketRegimeValue, string relativeStrengthStatusValue, bool useSectorBenchmark, float sectorRsScore, float sectorMinScore, string htfStatusValue, bool heavyMidMaBreak) =>
    score = 0.0
    score += extensionMidPct > extensionWarnPct ? 1.0 : 0.0
    score += extensionMidPct > extensionDangerPct ? 1.5 : 0.0
    score += rsiValue > 75.0 ? 0.8 : 0.0
    score += rsiValue > 80.0 ? 0.7 : 0.0
    score += nearResistance and not freshBreakout ? 0.7 : 0.0
    score += heavyRedNow ? 1.5 : 0.0
    score += distributionCount >= 3.0 ? 1.5 : 0.0
    score += failedBreakout ? 2.0 : 0.0
    score += gapExhaustion ? 1.5 : 0.0
    score += liquidityWarning ? 0.8 : 0.0
    score += atrPct > atrWarnPct ? 0.7 : 0.0
    score += atrPct > atrDangerPct ? 1.0 : 0.0
    score += marketRiskOffValue ? 1.5 : marketRegimeValue == marketBearish() ? 1.0 : marketRegimeValue == marketMixed() ? 0.4 : 0.0
    score += relativeStrengthStatusValue == rsWeak() ? 1.0 : relativeStrengthStatusValue == rsNeutral() ? 0.4 : 0.0
    score += useSectorBenchmark and sectorRsScore < sectorMinScore ? 0.7 : 0.0
    score += htfStatusValue == htfWeak() ? 1.0 : htfStatusValue == htfNeutral() ? 0.3 : 0.0
    score += heavyMidMaBreak ? 1.0 : 0.0
    clampScore(score)

export dualScore(float trendScoreValue, float momentumScoreValue, float setupScoreValue, float riskScoreValue, float marketScoreValue, float combinedRsScore, float htfScoreValue, string scoringMode) =>
    riskControlScore = 10.0 - riskScoreValue
    clampScore(
         trendScoreValue * (scoringMode == "Early Rocket" ? 0.20 : 0.25) +
         momentumScoreValue * (scoringMode == "Conservative" ? 0.20 : scoringMode == "Early Rocket" ? 0.30 : 0.25) +
         setupScoreValue * (scoringMode == "Conservative" ? 0.15 : 0.20) +
         riskControlScore * (scoringMode == "Conservative" ? 0.15 : 0.10) +
         marketScoreValue * (scoringMode == "Conservative" ? 0.10 : scoringMode == "Early Rocket" ? 0.05 : 0.08) +
         combinedRsScore * (scoringMode == "Conservative" ? 0.10 : scoringMode == "Early Rocket" ? 0.10 : 0.08) +
         htfScoreValue * (scoringMode == "Conservative" ? 0.05 : scoringMode == "Early Rocket" ? 0.05 : 0.04)
    )

export blowoffTop(bool trendOk, float extensionMidPct, float extensionDangerPct, float rsiValue, float volRatio, float upperWickPct, float candleRange, float atrValue) =>
    trendOk and extensionMidPct > extensionDangerPct and rsiValue > 72.0 and volRatio > 1.30 and (upperWickPct > 35.0 or candleRange > atrValue * 1.50)

export distributionRisk(float distributionCount, bool heavyRedNow, bool gapExhaustion, bool heavyMidMaBreakWithWeakRsi) =>
    distributionCount >= 3.0 or heavyRedNow or gapExhaustion or heavyMidMaBreakWithWeakRsi

export classifySetup(float trendScoreValue, float momentumScoreValue, float setupScoreValue, float riskScoreValue, bool hadPullback, bool notTooDeep, bool heldNearSupport, bool aboveMidMa, float rsiValue, float extensionMidPct, float extensionWarnPct, float extensionDangerPct, bool entryFiltersOk, bool allFiltersOk, bool distributionRiskValue, bool blowoffTopValue, bool failedBreakout, bool freshBreakout, float strongClose, bool aboveSlowMa, float midSlopePct, float combinedRsScore) =>
    primeCleanPullback = trendScoreValue >= 8.0 and momentumScoreValue >= 7.0 and setupScoreValue >= 8.0 and riskScoreValue <= 3.0 and hadPullback and notTooDeep and heldNearSupport and aboveMidMa and rsiValue >= 50.0 and rsiValue <= 70.0 and extensionMidPct <= extensionWarnPct and entryFiltersOk and not distributionRiskValue and not blowoffTopValue and not failedBreakout
    cleanBullPullback = not primeCleanPullback and trendScoreValue >= 7.0 and momentumScoreValue >= 6.5 and setupScoreValue >= 7.5 and riskScoreValue <= 4.0 and hadPullback and notTooDeep and heldNearSupport and aboveMidMa and rsiValue >= 50.0 and rsiValue <= 70.0 and entryFiltersOk and not distributionRiskValue and not blowoffTopValue and not failedBreakout
    freshBreakoutSignal = trendScoreValue >= 7.0 and momentumScoreValue >= 8.0 and setupScoreValue >= 6.5 and riskScoreValue <= 4.5 and freshBreakout and strongClose >= 0.65 and entryFiltersOk and not distributionRiskValue and not blowoffTopValue and not failedBreakout
    momentumContinuation = trendScoreValue >= 7.5 and momentumScoreValue >= 8.0 and riskScoreValue <= 5.0 and not primeCleanPullback and not cleanBullPullback and not freshBreakoutSignal and allFiltersOk and not distributionRiskValue and not blowoffTopValue and not failedBreakout
    extendedMomentum = trendScoreValue >= 6.5 and momentumScoreValue >= 7.0 and riskScoreValue <= 6.0 and not primeCleanPullback and not cleanBullPullback and not freshBreakoutSignal and not momentumContinuation and allFiltersOk and not distributionRiskValue and not blowoffTopValue and not failedBreakout and (extensionMidPct > extensionWarnPct or not hadPullback or rsiValue > 68.0 or freshBreakout)
    overheatedMomentum = trendScoreValue >= 6.5 and momentumScoreValue >= 7.0 and not primeCleanPullback and not cleanBullPullback and not freshBreakoutSignal and not momentumContinuation and not distributionRiskValue and not blowoffTopValue and not failedBreakout and (extensionMidPct > extensionDangerPct or rsiValue > 75.0 or extensionMidPct > extensionWarnPct and rsiValue > 70.0 or riskScoreValue >= 5.5)
    filteredPullback = not entryFiltersOk and trendScoreValue >= 7.0 and setupScoreValue >= 7.0 and hadPullback and notTooDeep and heldNearSupport and not distributionRiskValue and not blowoffTopValue and not failedBreakout
    filteredMomentum = not entryFiltersOk and trendScoreValue >= 6.5 and momentumScoreValue >= 7.0 and not distributionRiskValue and not blowoffTopValue and not failedBreakout
    trendRepair = not primeCleanPullback and not cleanBullPullback and not freshBreakoutSignal and not momentumContinuation and not extendedMomentum and not overheatedMomentum and not filteredPullback and not filteredMomentum and not distributionRiskValue and not blowoffTopValue and not failedBreakout and trendScoreValue >= 4.5 and trendScoreValue < 7.0 and momentumScoreValue >= 4.5 and aboveSlowMa and (aboveMidMa or midSlopePct > 0.0 or combinedRsScore >= 5.0)
    blowoffTopValue ? classBlowoffTop() :
         failedBreakout ? classFailedBreakout() :
         distributionRiskValue ? classDistributionRisk() :
         overheatedMomentum ? classOverheatedMomentum() :
         primeCleanPullback ? classPrimePullback() :
         cleanBullPullback ? classCleanPullback() :
         freshBreakoutSignal ? classFreshBreakout() :
         momentumContinuation ? classMomentumContinuation() :
         extendedMomentum ? classExtendedMomentum() :
         filteredPullback ? classFilteredPullback() :
         filteredMomentum ? classFilteredMomentum() :
         trendRepair ? classTrendRepair() :
         classNoTrade()

export pullbackHealthStatus(bool heavyRedNow, bool rsiCollapse, bool hadPullback, bool notTooDeep, bool heldNearSupport, bool aboveMidMa) =>
    heavyRedNow or rsiCollapse or hadPullback and not notTooDeep
         ? pullbackDangerous()
         : hadPullback and notTooDeep and heldNearSupport and aboveMidMa and not heavyRedNow
             ? pullbackHealthy()
             : pullbackMixed()

export filterProblemText(bool marketRiskOffValue, bool marketGateOk, bool sectorRelativeStrengthGateOk, bool relativeStrengthGateOk, bool htfGateOk, bool rewardRiskOk) =>
    marketRiskOffValue ? "Market risk-off" :
         not marketGateOk ? "Market failed" :
         not sectorRelativeStrengthGateOk ? "Sector RS failed" :
         not relativeStrengthGateOk ? "RS failed" :
         not htfGateOk ? "HTF failed" :
         not rewardRiskOk ? "R/R failed" :
         "Filter failed"

export actionBiasText(string classification, string buyableText, string filterProblem) =>
    classification == classPrimePullback() ? "Best buyable, " + buyableText :
         classification == classCleanPullback() ? "Buyable, " + buyableText :
         classification == classFreshBreakout() ? "Breakout buy, " + buyableText :
         classification == classMomentumContinuation() ? "Watch / trail / smaller size" :
         classification == classExtendedMomentum() ? "Do not chase, wait mini-pullback" :
         classification == classOverheatedMomentum() ? "Overheated, avoid chasing" :
         classification == classFilteredPullback() ? "Good chart, " + filterProblem :
         classification == classFilteredMomentum() ? "Momentum, " + filterProblem :
         classification == classTrendRepair() ? "Improving, not ready" :
         classification == classDistributionRisk() ? "Avoid / exit risk" :
         classification == classFailedBreakout() ? "Avoid" :
         classification == classBlowoffTop() ? "Avoid chasing" :
         "No clear trade"
